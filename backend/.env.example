# Server
PORT=3001
NODE_ENV=development

# CORS
CORS_ORIGIN=http://localhost:3000
CORS_EXTENSION_ORIGIN=chrome-extension://*

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# AI Provider
AI_PROVIDER=openai

# Cache
CACHE_TTL_MS=86400000

# JWT (optional, for auth features)
# JWT_SECRET=
